{
  "name": "@assertlabs/cli",
  "version": "0.1.7",
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "assert": "bin/assert.js"
  },
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Assert-Labs/cli.git"
  },
  "homepage": "https://github.com/Assert-Labs/cli#readme",
  "bugs": {
    "url": "https://github.com/Assert-Labs/cli/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "node scripts/build.mjs esm",
