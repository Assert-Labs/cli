            "content": "/**\n * Assert Trace Capture Hook\n *\n * This hook fires after each agent completion (stop event) to capture\n * agent traces for analysis and debugging via Assert Labs.\n *\n * Input (via stdin):\n * - conversation_id: string - Unique identifier for the conversation\n * - generation_id: string - Unique identifier for this generation\n * - status: \"completed\" | \"aborted\" | \"error\" | string - Completion status\n * - loop_count: number - Number of agentic loops executed\n * - transcript_path: string | null - Path to the transcript file\n *\n * Output (via stdout):\n * - Empty object {} if no follow-up action needed\n * - { followup_message: string } to trigger additional actions\n */\n\nimport { readFileSync, writeFileSync, mkdirSync, existsSync, statSync } from \"fs\";\nimport { join, dirname } from \"path\";\nimport { homedir } from \"os\";\n\n// ============================================================================\n// Types\n// ============================================================================\n\ninterface StopHookInput {\n  conversation_id: string;\n  generation_id?: string;\n  status: \"completed\" | \"aborted\" | \"error\" | string;\n  loop_count: number;\n  transcript_path?: string | null;\n}\n\ninterface StopHookOutput {\n  followup_message?: string;\n}\n\ninterface CapturedTrace {\n  timestamp: string;\n  conversation_id: string;\n  generation_id?: string;\n  status: string;\n  loop_count: number;\n  transcript_path?: string | null;\n  transcript_content?: string | null;\n  transcript_mtime?: number | null;\n}\n\ninterface AssertState {\n  version: number;\n  lastCapturedAtMs: number;\n  totalCapturedTraces: number;\n  lastProcessedGenerationId?: string;\n  capturedTraces: CapturedTrace[];\n}\n\n// ============================================================================\n// Configuration\n// ============================================================================\n\nconst STATE_DIR = join(process.cwd(), \".cursor\", \"hooks\", \"state\");\nconst STATE_FILE = join(STATE_DIR, \"assert-trace-capture.json\");\nconst TRACES_DIR = join(process.cwd(), \".cursor\", \"hooks\", \"state\", \"assert-traces\");\n\n// Maximum number of traces to keep in state (prevents unbounded growth)\nconst MAX_TRACES_IN_STATE = parseInt(process.env.ASSERT_MAX_TRACES || \"100\", 10);\n\n// Whether to capture full transcript content\nconst CAPTURE_TRANSCRIPT_CONTENT = process.env.ASSERT_CAPTURE_CONTENT !== \"false\";\n\n// Whether to deduplicate by generation_id\nconst DEDUPLICATE_BY_GENERATION = process.env.ASSERT_DEDUPLICATE !== \"false\";\n\n// ============================================================================\n// State Management\n// ============================================================================\n\nfunction ensureStateDir(): void {\n  if (!existsSync(STATE_DIR)) {\n    mkdirSync(STATE_DIR, { recursive: true });\n  }\n  if (!existsSync(TRACES_DIR)) {\n    mkdirSync(TRACES_DIR, { recursive: true });\n  }\n}\n\nfunction loadState(): AssertState {\n  ensureStateDir();\n\n  if (!existsSync(STATE_FILE)) {\n    return {\n      version: 1,\n      lastCapturedAtMs: 0,\n      totalCapturedTraces: 0,\n      capturedTraces: [],\n    };\n  }\n\n  try {\n    const raw = readFileSync(STATE_FILE, \"utf-8\");\n    return JSON.parse(raw) as AssertState;\n  } catch {\n    return {\n      version: 1,\n      lastCapturedAtMs: 0,\n      totalCapturedTraces: 0,\n      capturedTraces: [],\n    };\n  }\n}\n\nfunction saveState(state: AssertState): void {\n  ensureStateDir();\n  writeFileSync(STATE_FILE, JSON.stringify(state, null, 2), \"utf-8\");\n}\n\n// ============================================================================\n// Transcript Handling\n// ============================================================================\n\nfunction readTranscript(transcriptPath: string | null | undefined): {\n  content: string | null;\n  mtime: number | null;\n} {\n  if (!transcriptPath || !existsSync(transcriptPath)) {\n    return { content: null, mtime: null };\n  }\n\n  try {\n    const stats = statSync(transcriptPath);\n    const content = CAPTURE_TRANSCRIPT_CONTENT\n      ? readFileSync(transcriptPath, \"utf-8\")\n      : null;\n\n    return {\n      content,\n      mtime: stats.mtimeMs,\n    };\n  } catch {\n    return { content: null, mtime: null };\n  }\n}\n\nfunction saveTraceToFile(trace: CapturedTrace): string {\n  ensureStateDir();\n\n  const filename = `trace-${trace.conversation_id}-${Date.now()}.json`;\n  const filepath = join(TRACES_DIR, filename);\n\n  writeFileSync(filepath, JSON.stringify(trace, null, 2), \"utf-8\");\n\n  return filepath;\n}\n\n// ============================================================================\n// Main Hook Logic\n// ============================================================================\n\nfunction shouldCapture(input: StopHookInput, state: AssertState): boolean {\n  // Always capture completed traces\n  if (input.status !== \"completed\") {\n    // Optionally capture aborted/error traces based on config\n    const captureNonCompleted = process.env.ASSERT_CAPTURE_ALL === \"true\";\n    if (!captureNonCompleted) {\n      return false;\n    }\n  }\n\n  // Deduplicate by generation_id if enabled\n  if (DEDUPLICATE_BY_GENERATION && input.generation_id) {\n    if (state.lastProcessedGenerationId === input.generation_id) {\n      return false;\n    }\n  }\n\n  return true;\n}\n\nfunction captureTrace(input: StopHookInput, state: AssertState): CapturedTrace {\n  const { content, mtime } = readTranscript(input.transcript_path);\n\n  const trace: CapturedTrace = {\n    timestamp: new Date().toISOString(),\n    conversation_id: input.conversation_id,\n    generation_id: input.generation_id,\n    status: input.status,\n    loop_count: input.loop_count,\n    transcript_path: input.transcript_path,\n    transcript_content: content,\n    transcript_mtime: mtime,\n  };\n\n  return trace;\n}\n\nfunction updateState(state: AssertState, trace: CapturedTrace, input: StopHookInput): AssertState {\n  const newTraces = [...state.capturedTraces, trace];\n\n  // Trim to max traces\n  while (newTraces.length > MAX_TRACES_IN_STATE) {\n    newTraces.shift();\n  }\n\n  return {\n    ...state,\n    version: 1,\n    lastCapturedAtMs: Date.now(),\n    totalCapturedTraces: state.totalCapturedTraces + 1,\n    lastProcessedGenerationId: input.generation_id,\n    capturedTraces: newTraces,\n  };\n}\n\n// ============================================================================\n// Entry Point\n// ============================================================================\n\nasync function main(): Promise<void> {\n  // Read input from stdin\n  let inputJson = \"\";\n  for await (const chunk of Bun.stdin.stream()) {\n    inputJson += new TextDecoder().decode(chunk);\n  }\n\n  let input: StopHookInput;\n  try {\n    input = JSON.parse(inputJson);\n  } catch {\n    // Invalid input, exit silently\n    console.log(JSON.stringify({}));\n    return;\n  }\n\n  const state = loadState();\n  const output: StopHookOutput = {};\n\n  if (shouldCapture(input, state)) {\n    const trace = captureTrace(input, state);\n\n    // Save trace to individual file for persistence\n    const traceFile = saveTraceToFile(trace);\n\n    // Update state\n    const newState = updateState(state, trace, input);\n    saveState(newState);\n\n    // Log for debugging (goes to stderr, not stdout)\n    console.error(`[Assert] Captured trace: ${trace.conversation_id} (${trace.status})`);\n    console.error(`[Assert] Trace saved to: ${traceFile}`);\n    console.error(`[Assert] Total traces captured: ${newState.totalCapturedTraces}`);\n\n    // Optionally trigger a follow-up action (e.g., upload to Assert backend)\n    // Uncomment the following to enable follow-up messages:\n    // if (process.env.ASSERT_ENABLE_FOLLOWUP === \"true\") {\n    //   output.followup_message = \"Run the `assert-upload` skill to sync traces.\";\n    // }\n  }\n\n  // Output result\n  console.log(JSON.stringify(output));\n}\n\nmain().catch((err) => {\n  console.error(\"[Assert] Hook error:\", err);\n  console.log(JSON.stringify({}));\n  process.exit(1);\n});\n",
